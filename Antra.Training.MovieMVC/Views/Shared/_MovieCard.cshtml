@model ApplicationCore.Models.MovieCardModel

<div class="card h-100 shadow-sm">
    <img src="@Model.PosterUrl" class="card-img-top" alt="@Model.Title" style="height:300px; object-fit:cover;" />
    <div class="card-body d-flex flex-column">
        <h5 class="card-title">@Model.Title</h5>
        <p class="card-text text-muted mt-auto">$@Model.Price.ToString("0.00")</p>
        <a asp-controller="Movies" asp-action="Details" asp-route-id="@Model.Id" class="btn btn-primary btn-sm mt-2">View Details</a>
    </div>
</div>
