@using ApplicationCore.Models.Response
@model CastDetailsResponse

@{
    ViewData["Title"] = Model.Name;
}

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-md-3 text-center">
            @if (!string.IsNullOrEmpty(Model.ProfilePath))
            {
                <img src="@Model.ProfilePath" alt="@Model.Name"
                     class="img-fluid rounded shadow" style="max-height:400px;" />
            }
            else
            {
                <div class="bg-secondary text-white d-flex align-items-center justify-content-center rounded"
                     style="height:300px;">No Photo</div>
            }
        </div>

        <div class="col-md-9">
            <h2>@Model.Name</h2>
            <ul class="list-group list-group-flush mb-3" style="max-width:400px;">
                <li class="list-group-item d-flex justify-content-between">
                    <strong>Gender</strong>
                    <span>@(Model.Gender ?? "N/A")</span>
                </li>
                @if (!string.IsNullOrEmpty(Model.TmdbUrl))
                {
                    <li class="list-group-item">
                        <strong>TMDB</strong>
                        <a href="@Model.TmdbUrl" target="_blank" class="ms-2">View on TMDB</a>
                    </li>
                }
            </ul>

            <h5 class="mt-4 mb-3">Movies</h5>
            @if (Model.Movies.Any())
            {
                <ul class="list-group">
                    @foreach (var movie in Model.Movies)
                    {
                        <li class="list-group-item list-group-item-action">
                            <a asp-controller="Movies" asp-action="Details" asp-route-id="@movie.Id"
                               class="d-flex align-items-center text-decoration-none text-dark">
                                @if (!string.IsNullOrEmpty(movie.PosterUrl))
                                {
                                    <img src="@movie.PosterUrl" alt="@movie.Title"
                                         class="me-3 rounded" style="width:48px;height:72px;object-fit:cover;" />
                                }
                                <div>
                                    <div class="fw-bold">@movie.Title</div>
                                    @if (movie.ReleaseDate.HasValue)
                                    {
                                        <small class="text-muted">@movie.ReleaseDate.Value.Year</small>
                                    }
                                </div>
                            </a>
                        </li>
                    }
                </ul>
            }
            else
            {
                <p class="text-muted">No movies found for this cast member.</p>
            }
        </div>
    </div>

    <a asp-controller="Movies" asp-action="Index" class="btn btn-outline-secondary mt-3">
        &larr; Back to Movies
    </a>
</div>
